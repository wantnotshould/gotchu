@import './theme.wxss';

page {
	height: 100%;
	box-sizing: border-box;
	margin: 0;
	padding: 0;
	line-height: 1.6;
}

view,
text,
scroll-view {
	box-sizing: border-box;
	margin: 0;
	padding: 0;
}

.container {
	box-sizing: border-box;
	color: var(--vk-text);
	padding-top: 44rpx;
}

.line {
	width: 100%;
	height: 2rpx;
	background-color: var(--line);
	margin: 20rpx 0;
}