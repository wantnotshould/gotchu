<!--pages/create/create.wxml-->
<navigation-bar title="TOTP 添加" back="{{true}}"></navigation-bar>

<view class="page-container">
  <view class="scan-section" bindtap="onScanCode">
    <text>扫描二维码添加</text>
  </view>

  <view class="divider">或者手动输入</view>

  <view class="form-card">
    <view class="form-item">
      <text class="label">账号名称</text>
      <input placeholder="如: gotchu" value="{{label}}" data-field="label" bindinput="onInputChange" />
    </view>

    <view class="form-item">
      <text class="label">发行方</text>
      <input placeholder="如: GitHub (可选)" value="{{issuer}}" data-field="issuer" bindinput="onInputChange" />
    </view>

    <view class="form-item">
      <text class="label">密钥</text>
      <input placeholder="请输入或通过扫码获取 (Base32)" value="{{secret}}" data-field="secret" bindinput="onInputChange" />
    </view>

    <view class="form-item">
      <text class="label">位数</text>
      <radio-group data-field="digits" bindchange="onInputChange">
        <label class="radio-label">
          <radio value="6" checked="{{digits == 6}}" /> 6位
        </label>
        <label class="radio-label">
          <radio value="8" checked="{{digits == 8}}" /> 8位
        </label>
      </radio-group>
    </view>

    <view class="form-item">
      <text class="label">算法</text>
      <picker class="picker-flex" range="{{algoRange}}" bindchange="onAlgoChange">
        <view class="value">{{algoRange[algorithm - 1]}}</view>
      </picker>
    </view>

    <view class="form-item">
      <text class="label">步长（秒）</text>
      <picker class="picker-flex" range="{{[30, 60]}}" bindchange="onPeriodChange">
        <view class="value">{{period}} 秒</view>
      </picker>
    </view>
  </view>

  <button class="save-btn" bindtap="saveItem">保存并添加</button>
</view>