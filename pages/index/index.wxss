/**index.wxss**/
page {
  background-color: var(--bg);
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.list-container {
  padding: 20rpx 26rpx;
}

.card {
  background-color: var(--bg);
  border-radius: 16rpx;
  padding: 16rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid var(--border);
  transition: all 0.2s;
}

.card:active {
  transform: scale(0.98);
  background-color: var(--btn);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.label {
  font-size: 34rpx;
  font-weight: bold;
  color: var(--accent);
}

.issuer {
  font-size: 26rpx;
  color: var(--second-text);
  font-weight: 600;
  border: 2rpx solid var(--border);
  padding: 4rpx 12rpx;
  border-radius: 500rem;
}

.card-body {
  position: relative;
}

.code-wrapper {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.code {
  font-family: monospace;
  font-size: 57rpx;
  font-weight: 600;
  color: var(--success);
  letter-spacing: 4rpx;
}

.progress-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

progress {
  flex: 1;
  margin-right: 20rpx;
}

.time-text {
  font-size: 24rpx;
  color: var(--second-text);
  width: 40rpx;
  text-align: right;
}

.fab {
  position: fixed;
  right: 57rpx;
  bottom: 72rpx;
  width: 110rpx;
  height: 110rpx;
  background-color: var(--primary);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 100;
}

.fab-icon {
  position: absolute;
  color: #fff;
  font-size: 60rpx;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
  color: var(--second-text);
  font-size: 28rpx;
}

.footer-spacing {
  height: 150rpx;
}